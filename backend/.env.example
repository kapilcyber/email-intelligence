# Microsoft Graph (Azure AD app registration)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Default mailbox for backfill / webhook (e.g. user@yourdomain.com)
MAILBOX_EMAIL=

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_intelligence

# Redis
REDIS_URL=redis://localhost:6379/0

# App
ENVIRONMENT=development

# Phase 2 — OpenAI (required for AI classification)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
