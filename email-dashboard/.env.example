# Backend API (Phase 1)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Microsoft sign-in (NextAuth) — same Azure AD app as backend; add redirect URI in Azure Portal:
# Redirect URI: http://localhost:3001/api/auth/callback/azure-ad
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# Optional: if not set here, copy from backend .env (AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
